#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PLUGIN_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/state.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/parse-turns.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/tmux-nav.sh"

install_tmux_cmd() {
  turn_nav_in_tmux || exit 0
  "$(turn_nav_tmux_bin)" set-option -gq @turn_nav_root "$PLUGIN_ROOT"
  "$(turn_nav_tmux_bin)" source-file "$PLUGIN_ROOT/tmux/turn-nav.conf"
}

activate_cmd() {
  turn_nav_in_tmux || exit 0
  local pane_id=${1:-$(turn_nav_current_pane_id)}
  local content baseline
  content=$(turn_nav_capture_pane "$pane_id")
  baseline=$(turn_nav_count_completed_turns "$content")
  turn_nav_write_state "$pane_id" baseline_turn_count "$baseline"
  turn_nav_delete_state "$pane_id" current_turn
  turn_nav_delete_state "$pane_id" last_status
  turn_nav_delete_state "$pane_id" visible_turn_count
  turn_nav_close_list_pane "$pane_id"
  turn_nav_write_state "$pane_id" active 1
}

deactivate_cmd() {
  turn_nav_in_tmux || exit 0
  local pane_id=${1:-$(turn_nav_current_pane_id)}
  turn_nav_close_list_pane "$pane_id"
  turn_nav_clear_pane_state "$pane_id"
}

bottom_cmd() {
  turn_nav_in_tmux || exit 0
  local pane_id=$1
  turn_nav_delete_state "$pane_id" current_turn
  turn_nav_delete_state "$pane_id" last_status
  turn_nav_delete_state "$pane_id" visible_turn_count
  turn_nav_close_list_pane "$pane_id"
  if [[ "$(turn_nav_pane_in_copy_mode "$pane_id")" == "1" ]]; then
    turn_nav_cancel_copy_mode "$pane_id"
  fi
}

turn_nav_close_list_pane() {
  local pane_id=$1
  local list_pane
  list_pane=$(turn_nav_read_state "$pane_id" list_pane_id "")
  if [[ -n "$list_pane" ]] && turn_nav_pane_exists "$list_pane"; then
    turn_nav_kill_pane "$list_pane" || true
  fi
  turn_nav_delete_state "$pane_id" list_pane_id
  turn_nav_delete_state "$pane_id" list_file
}

turn_nav_label_for_display() {
  local label=$1
  local default_width=100
  if [[ "$(turn_nav_list_position)" == "right" ]]; then
    default_width=60
  fi
  local max_width=${TURN_NAV_LABEL_WIDTH:-$default_width}
  if ((${#label} > max_width)); then
    printf '%s...\n' "${label:0:max_width}"
  else
    printf '%s\n' "$label"
  fi
}

turn_nav_list_min_height() {
  local min_height=${TURN_NAV_LIST_MIN_HEIGHT:-5}
  if turn_nav_is_nonnegative_integer "$min_height" && (( min_height > 0 )); then
    printf '%s\n' "$min_height"
  else
    printf '5\n'
  fi
}

turn_nav_list_max_height_for_pane() {
  local pane_id=$1
  local min_height pane_height percent max_height
  min_height=$(turn_nav_list_min_height)
  pane_height=$(turn_nav_pane_height "$pane_id" 2>/dev/null || true)
  percent=${TURN_NAV_LIST_MAX_HEIGHT_PERCENT:-30}
  if ! turn_nav_is_nonnegative_integer "$pane_height" || (( pane_height < 2 )); then
    printf '%s\n' "$min_height"
    return 0
  fi
  if ! turn_nav_is_nonnegative_integer "$percent" || (( percent < 1 )); then
    percent=30
  fi
  max_height=$((pane_height * percent / 100))
  (( max_height < min_height )) && max_height=$min_height
  if (( max_height >= pane_height )); then
    max_height=$((pane_height - 1))
  fi
  (( max_height < 1 )) && max_height=1
  printf '%s\n' "$max_height"
}

turn_nav_list_height_for_total() {
  local pane_id=$1
  local total=$2
  local min_height max_height full_height height
  min_height=$(turn_nav_list_min_height)
  if [[ "$(turn_nav_list_position)" == "right" ]]; then
    printf '\n'
    return 0
  fi
  max_height=$(turn_nav_list_max_height_for_pane "$pane_id")
  full_height=$((total + 2))
  height=$full_height
  (( height < min_height )) && height=$min_height
  (( height > max_height )) && height=$max_height
  printf '%s\n' "$height"
}

turn_nav_turn_list_window() {
  local current=$1
  local total=$2
  local target_height=$3
  local fallback_max_rows=$4
  local start=1
  local end=$total
  if turn_nav_is_nonnegative_integer "$target_height" && (( target_height > 2 )); then
    local rows_available slots extra
    rows_available=$((target_height - 2))
    if (( total > rows_available )); then
      for ((slots = rows_available; slots > 0; slots--)); do
        start=$((current - (slots / 2)))
        (( start < 1 )) && start=1
        end=$((start + slots - 1))
        if (( end > total )); then
          end=$total
          start=$((end - slots + 1))
          (( start < 1 )) && start=1
        fi
        extra=0
        (( start > 1 )) && extra=$((extra + 1))
        (( end < total )) && extra=$((extra + 1))
        if (( slots + extra <= rows_available )); then
          break
        fi
      done
    fi
  elif turn_nav_is_nonnegative_integer "$fallback_max_rows" && (( total > fallback_max_rows )); then
    start=$((current - (fallback_max_rows / 2)))
    (( start < 1 )) && start=1
    end=$((start + fallback_max_rows - 1))
    if (( end > total )); then
      end=$total
      start=$((end - fallback_max_rows + 1))
      (( start < 1 )) && start=1
    fi
  fi
  printf '%s\t%s\n' "$start" "$end"
}

turn_nav_render_turn_list() {
  local pane_id=$1
  local current=$2
  local total=$3
  local target_height=${4:-}
  shift 4
  local list_file
  list_file=$(turn_nav_read_state "$pane_id" list_file "")
  if [[ -z "$list_file" ]]; then
    list_file="$(turn_nav_pane_dir "$pane_id")/turn-list"
    turn_nav_write_state "$pane_id" list_file "$list_file"
  fi

  local max_rows=${TURN_NAV_LIST_MAX_ROWS:-30}
  local start end
  IFS=$'\t' read -r start end < <(turn_nav_turn_list_window "$current" "$total" "$target_height" "$max_rows")

  local record index _line label marker display_label
  {
    printf 'Turn %s/%s\n' "$current" "$total"
    printf '%s\n' '------------'
    if (( start > 1 )); then
      printf '  ...\n'
    fi
    for record in "$@"; do
      IFS=$'\t' read -r index _line label <<<"$record"
      if (( index < start || index > end )); then
        continue
      fi
      marker=" "
      if (( index == current )); then
        marker=">"
      fi
      display_label=$(turn_nav_label_for_display "$label")
      printf '%s %s  %s\n' "$marker" "$index" "$display_label"
    done
    if (( end < total )); then
      printf '  ...\n'
    fi
  } >"$list_file"
}

turn_nav_ensure_list_pane() {
  local pane_id=$1
  local list_height=${2:-}
  local list_file
  list_file=$(turn_nav_read_state "$pane_id" list_file "")
  if [[ -z "$list_file" ]]; then
    list_file="$(turn_nav_pane_dir "$pane_id")/turn-list"
    turn_nav_write_state "$pane_id" list_file "$list_file"
  fi

  local list_pane
  list_pane=$(turn_nav_read_state "$pane_id" list_pane_id "")
  if [[ -n "$list_pane" ]] && turn_nav_pane_exists "$list_pane"; then
    return 0
  fi

  turn_nav_delete_state "$pane_id" list_pane_id
  list_pane=$(turn_nav_split_list_pane "$pane_id" "$list_file" "$list_height") || return 0
  turn_nav_write_state "$pane_id" list_pane_id "$list_pane"
  turn_nav_select_pane "$pane_id" || true
}

turn_nav_should_search_jump() {
  local pane_id=$1
  local pane_height cursor_y
  pane_height=$(turn_nav_pane_height "$pane_id" 2>/dev/null || true)
  cursor_y=$(turn_nav_cursor_y "$pane_id" 2>/dev/null || true)
  if turn_nav_is_nonnegative_integer "$pane_height" && turn_nav_is_nonnegative_integer "$cursor_y"; then
    (( pane_height - cursor_y - 1 > 3 ))
    return
  fi
  return 1
}

turn_nav_line_at() {
  local content=$1
  local line_number=$2
  if ! turn_nav_is_nonnegative_integer "$line_number" || (( line_number < 1 )); then
    return 0
  fi
  printf '%s\n' "$content" | sed -n "${line_number}p" | sed -E 's/[[:space:]]+$//'
}

turn_nav_search_text_for_line() {
  local content=$1
  local line_number=$2
  local fallback=$3
  local search_text max_width delimiter candidate truncated shortened
  shortened=0
  search_text=$(turn_nav_line_at "$content" "$line_number")
  if [[ -z "$search_text" ]]; then
    search_text=$fallback
  fi

  for delimiter in "，" "。" "？" "?" "；" ";" "," "：" ":"; do
    candidate=${search_text%%"$delimiter"*}
    if [[ "$candidate" != "$search_text" && ${#candidate} -ge 8 ]]; then
      search_text=$candidate
      shortened=1
      break
    fi
  done

  max_width=${TURN_NAV_SEARCH_TEXT_WIDTH:-41}
  if (( shortened == 0 )) && turn_nav_is_nonnegative_integer "$max_width" && (( max_width > 0 && ${#search_text} > max_width )); then
    truncated=$(printf '%s\n' "$search_text" | LC_ALL="${TURN_NAV_UTF8_LOCALE:-en_US.UTF-8}" awk -v max="$max_width" '{ print substr($0, 1, max); exit }' 2>/dev/null || true)
    if [[ -n "$truncated" ]]; then
      search_text=$truncated
    fi
  fi
  printf '%s\n' "$search_text"
}

navigate_cmd() {
  turn_nav_in_tmux || exit 0
  local direction=$1
  local count=$2
  local pane_id=$3

  turn_nav_is_nonnegative_integer "$count" || exit 0
  if ! turn_nav_is_active "$pane_id"; then
    turn_nav_write_state "$pane_id" baseline_turn_count 0
    turn_nav_delete_state "$pane_id" current_turn
    turn_nav_delete_state "$pane_id" last_status
    turn_nav_delete_state "$pane_id" visible_turn_count
    turn_nav_write_state "$pane_id" active 1
  fi

  local in_copy
  in_copy=$(turn_nav_pane_in_copy_mode "$pane_id")
  if [[ "$in_copy" == "1" ]]; then
    turn_nav_close_list_pane "$pane_id"
    turn_nav_cancel_copy_mode "$pane_id"
  fi

  local content baseline total_lines
  content=$(turn_nav_capture_pane "$pane_id")
  baseline=$(turn_nav_read_state "$pane_id" baseline_turn_count 0)
  turn_nav_is_nonnegative_integer "$baseline" || exit 0

  local records=()
  local record
  while IFS= read -r record; do
    records+=("$record")
  done < <(turn_nav_visible_turn_records "$content" "$baseline")
  local total=${#records[@]}
  if (( total == 0 && baseline > 0 )); then
    baseline=0
    turn_nav_write_state "$pane_id" baseline_turn_count "$baseline"
    turn_nav_delete_state "$pane_id" current_turn
    turn_nav_delete_state "$pane_id" last_status
    turn_nav_delete_state "$pane_id" visible_turn_count
    records=()
    while IFS= read -r record; do
      records+=("$record")
    done < <(turn_nav_visible_turn_records "$content" "$baseline")
    total=${#records[@]}
  fi

  if [[ "$in_copy" == "1" ]]; then
    local saved_total
    saved_total=$(turn_nav_read_state "$pane_id" visible_turn_count "")
    if turn_nav_is_nonnegative_integer "$saved_total" && (( saved_total > 0 && total > saved_total )); then
      baseline=$((baseline + total - saved_total))
      turn_nav_write_state "$pane_id" baseline_turn_count "$baseline"
      records=()
      while IFS= read -r record; do
        records+=("$record")
      done < <(turn_nav_visible_turn_records "$content" "$baseline")
      total=${#records[@]}
    fi
  fi
  if (( total == 0 )); then
    turn_nav_show_message "$pane_id" "No turns found"
    exit 0
  fi

  local current new
  if [[ "$in_copy" == "1" ]]; then
    current=$(turn_nav_read_state "$pane_id" current_turn "")
    if [[ -z "$current" ]]; then
      current=$((total + 1))
    elif ! turn_nav_is_nonnegative_integer "$current"; then
      current=$((total + 1))
    else
      if (( current < 1 )); then
        current=1
      fi
      if (( current > total )); then
        current=$total
      fi
    fi
  else
    current=$((total + 1))
  fi

  if [[ "$direction" == "up" ]]; then
    new=$((current - count))
    (( new < 1 )) && new=1
  else
    new=$((current + count))
    (( new > total )) && new=$total
  fi

  local status
  status=$(turn_nav_status_text "$new" "$total")
  local list_height
  list_height=$(turn_nav_list_height_for_total "$pane_id" "$total")
  turn_nav_write_state "$pane_id" current_turn "$new"
  turn_nav_write_state "$pane_id" last_status "$status"
  turn_nav_write_state "$pane_id" visible_turn_count "$total"
  turn_nav_render_turn_list "$pane_id" "$new" "$total" "$list_height" "${records[@]}"

  local was_in_copy=$in_copy
  if [[ "$(turn_nav_pane_in_copy_mode "$pane_id")" == "0" ]]; then
    turn_nav_enter_copy_mode "$pane_id"
  fi

  # Entering copy-mode can expose a different wrapped-line map from the live
  # pane. Re-capture before opening the list pane so the jump uses copy-mode
  # coordinates without letting split-induced reflow truncate the turn list.
  content=$(turn_nav_capture_pane "$pane_id")
  local jump_records=("${records[@]}")
  local copy_records=()
  while IFS= read -r record; do
    copy_records+=("$record")
  done < <(turn_nav_visible_turn_records "$content" "$baseline")
  if ((${#copy_records[@]} >= new)); then
    jump_records=("${copy_records[@]}")
  fi

  if [[ "$new" == "$current" && "$was_in_copy" != "1" ]]; then
    turn_nav_ensure_list_pane "$pane_id" "$list_height"
    turn_nav_show_message "$pane_id" "$status"
    exit 0
  fi

  total_lines=$(turn_nav_effective_bottom_line "$pane_id")
  if ! turn_nav_is_nonnegative_integer "$total_lines"; then
    total_lines=$(printf '%s\n' "$content" | wc -l | tr -d ' ')
  fi
  local target_line target_label
  IFS=$'\t' read -r _record_index target_line target_label <<<"${jump_records[$((new - 1))]}"
  local goto_line=$((total_lines - target_line))
  (( goto_line < 0 )) && goto_line=0
  local top_cursor_down_count history_size
  top_cursor_down_count=
  history_size=$(turn_nav_history_size "$pane_id")
  if turn_nav_is_nonnegative_integer "$history_size" && (( goto_line > history_size )); then
    top_cursor_down_count=$((target_line - 1))
    goto_line=$history_size
  fi

  local search_text=
  if [[ "$was_in_copy" == "1" ]] || turn_nav_should_search_jump "$pane_id"; then
    search_text=$(turn_nav_search_text_for_line "$content" "$target_line" "$target_label")
  fi
  local prefer_verified_goto=0
  if [[ "$was_in_copy" == "1" ]]; then
    prefer_verified_goto=1
  fi
  turn_nav_jump_to_line "$pane_id" "$goto_line" "$top_cursor_down_count" "$search_text" "$prefer_verified_goto"
  turn_nav_ensure_list_pane "$pane_id" "$list_height"
  turn_nav_show_message "$pane_id" "$status"
}

status_cmd() {
  turn_nav_in_tmux || exit 0
  local pane_id=$1
  turn_nav_is_active "$pane_id" || exit 0
  [[ "$(turn_nav_pane_in_copy_mode "$pane_id")" == "1" ]] || exit 0
  turn_nav_read_state "$pane_id" last_status ""
}

main() {
  local command=${1:-}
  case "$command" in
    install-tmux) shift; install_tmux_cmd "$@" ;;
    activate) shift; activate_cmd "$@" ;;
    deactivate) shift; deactivate_cmd "$@" ;;
    navigate) shift; navigate_cmd "$@" ;;
    bottom) shift; bottom_cmd "$@" ;;
    status) shift; status_cmd "$@" ;;
    *)
      printf 'usage: %s {install-tmux|activate|deactivate|navigate|bottom|status}\n' "$0" >&2
      exit 1
      ;;
  esac
}

main "$@"
